# Copy to .env for local development. Do not commit real secrets.

APP_ENV=development
APP_NAME=bezp

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bezp
POSTGRES_USER=bezp
POSTGRES_PASSWORD=bezp_dev_password

REDIS_HOST=localhost
REDIS_PORT=6379

SERVER_HOST=0.0.0.0
SERVER_PORT=8000

CLIENT_ORIGIN=http://localhost:5173
PROCTOR_DASHBOARD_ORIGIN=http://localhost:5174

JWT_ISSUER=replace-with-institution-issuer
JWT_AUDIENCE=bezp-local
JWT_PUBLIC_KEY_PATH=./configs/dev-jwt-public.pem

FL_ROUND_MIN_SUBMISSIONS=50
FL_ROUND_MAX_AGE_DAYS=7
DP_EPSILON=0.5
DP_DELTA=0.000001
